{
  "name": "mepcli",
  "version": "2.0.0-beta.2",
  "description": "Zero-dependency interactive CLI prompt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeTease/mep.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "swc src -d dist --config-file .swcrc",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "demo": "bun example.ts",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src"
  },
  "keywords": [
    "cli",
    "prompt",
    "prompts",
    "inquirer",
    "enquirer",
    "interactive",
    "interact",
    "zero-dependency",
    "codetease",
    "command-line",
    "typescript",
    "color",
    "ansi",
    "ui",
    "terminal",
    "command-line",
    "mep",
    "mepcli"
  ],
  "author": "CodeTease",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/node": "^22.19.13",
    "typescript": "^5.9.3"
  }
}