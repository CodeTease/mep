{
  "name": "mepcli",
  "version": "1.4.0",
  "description": "Zero-dependency, interactive CLI prompt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeTease/mep.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "swc src -d dist --config-file .swcrc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "demo": "ts-node example.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "cli",
    "prompt",
    "prompts",
    "inquirer",
    "enquirer",
    "interactive",
    "interact",
    "zero-dependency",
    "codetease",
    "command-line",
    "typescript",
    "color",
    "ansi",
    "ui",
    "terminal",
    "command-line",
    "mep",
    "mepcli"
  ],
  "author": "CodeTease",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.13",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}